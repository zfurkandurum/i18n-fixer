{
  "name": "django",
  "displayName": "Django (Python)",
  "fileExtensions": [".py", ".html"],
  "i18nFunctionPatterns": [
    "_\\(['\"](?P<key>[^'\"]+)['\"]",
    "gettext\\(['\"](?P<key>[^'\"]+)['\"]",
    "gettext_lazy\\(['\"](?P<key>[^'\"]+)['\"]",
    "ngettext\\(['\"](?P<key>[^'\"]+)['\"]",
    "ugettext\\(['\"](?P<key>[^'\"]+)['\"]",
    "{%\\s*trans\\s+['\"](?P<key>[^'\"]+)['\"]",
    "{%\\s*blocktrans\\s+[^%]*%}\\s*(?P<key>[^{%]{2,})"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]",
    "messages\\.(?:error|success|warning|info)\\(request,\\s*['\"](?P<str>[^'\"]{2,})['\"]",
    "raise\\s+(?:ValidationError|PermissionDenied)\\(['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "^#",
    "^\\{%",
    "import\\s",
    "class\\s",
    "def\\s",
    "verbose_name"
  ],
  "i18nFilePatterns": [
    "locale/**/LC_MESSAGES/*.json",
    "locale/**/LC_MESSAGES/*.yaml",
    "**/locale/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "manage.py", "containsAny": ["django"] },
    { "file": "settings.py", "containsAny": ["django"] }
  ],
  "ignorePatterns": [
    "**/__pycache__/**",
    "**/migrations/**",
    "**/.git/**",
    "**/venv/**",
    "**/env/**",
    "**/*.pyc",
    "**/staticfiles/**",
    "**/media/**",
    "**/tests/**",
    "**/*_test.py",
    "**/test_*.py"
  ]
}
