{
  "name": "rails-erb",
  "displayName": "Ruby on Rails (ERB / I18n)",
  "fileExtensions": [".rb", ".erb", ".html.erb"],
  "i18nFunctionPatterns": [
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]",
    "I18n\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "I18n\\.translate\\(['\"](?P<key>[^'\"]+)['\"]",
    "translate\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label):\\s*['\"](?P<str>[^'\"]{2,})['\"]",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]",
    "flash\\[:(?:notice|alert|error)\\]\\s*=\\s*['\"](?P<str>[^'\"]{2,})['\"]",
    "redirect_to[^,]+,\\s*notice:\\s*['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(_[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "^#",
    "^<%=",
    "require\\s",
    "class\\s",
    "def\\s",
    "end$"
  ],
  "i18nFilePatterns": [
    "config/locales/**/*.yml",
    "config/locales/**/*.yaml",
    "config/locales/*.yml"
  ],
  "i18nFileFormat": "yaml",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "Gemfile", "containsAny": ["rails"] },
    { "file": "config/application.rb" }
  ],
  "ignorePatterns": [
    "**/tmp/**",
    "**/log/**",
    "**/vendor/**",
    "**/.git/**",
    "**/public/**",
    "**/node_modules/**",
    "**/*.min.js",
    "**/spec/**",
    "**/test/**",
    "**/*_spec.rb",
    "**/*_test.rb"
  ]
}
