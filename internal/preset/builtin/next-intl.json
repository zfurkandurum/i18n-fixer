{
  "name": "next-intl",
  "displayName": "Next.js (next-intl)",
  "fileExtensions": [".tsx", ".ts", ".jsx", ".js"],
  "i18nFunctionPatterns": [
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]",
    "useTranslations\\(['\"](?P<key>[^'\"]*)['\"]\\)",
    "getTranslations\\(['\"](?P<key>[^'\"]*)['\"]\\)"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "className=",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "messages/**/*.json",
    "src/messages/**/*.json",
    "locales/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["next-intl"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**", "**/.next/**", "**/out/**", "**/.git/**"
  ]
}
