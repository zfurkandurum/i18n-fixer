{
  "name": "angular",
  "displayName": "Angular (@angular/localize)",
  "fileExtensions": [".ts", ".html"],
  "i18nFunctionPatterns": [
    "\\$localize`[^`]*:(?P<key>[^:@|]+)[:|@]",
    "i18n=\"(?P<key>[^\"]+)\"",
    "i18n-[a-z]+=\"(?P<key>[^\"]+)\""
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=\"(?P<str>[^\"]{2,})\""
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "class=\"",
    "\\*ngIf",
    "\\*ngFor",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "src/locale/**/*.json",
    "src/locale/**/*.xlf",
    "src/assets/i18n/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["@angular/localize"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**", "**/dist/**", "**/.git/**", "**/.angular/**"
  ]
}
