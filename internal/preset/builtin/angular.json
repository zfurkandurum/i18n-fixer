{
  "name": "angular",
  "displayName": "Angular (@angular/localize)",
  "fileExtensions": [
    ".ts",
    ".html"
  ],
  "i18nFunctionPatterns": [
    "\\$localize`[^`]*:(?P<key>[^:@|]+)[:|@]",
    "i18n=\"(?P<key>[^\"]+)\"",
    "i18n-[a-z]+=\"(?P<key>[^\"]+)\""
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=\"(?P<str>[^\"]{2,})\"",
    "=>[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "return[\\s]+['\"](?P<str>[^'\"]{2,})['\"]",
    "throw new Error\\(['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{\\{",
    "class=\"",
    "\\*ngIf",
    "\\*ngFor",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/i18n/**/*.json",
    "**/i18n/**/*.xlf",
    "**/locale/**/*.json",
    "**/locale/**/*.xlf",
    "**/locales/**/*.json",
    "**/locales/**/*.xlf",
    "**/lang/**/*.json",
    "**/translations/**/*.json",
    "**/assets/i18n/**/*.json",
    "**/assets/locales/**/*.json",
    "**/assets/lang/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    {
      "file": "package.json",
      "containsAny": [
        "@angular/localize"
      ]
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.git/**",
    "**/.angular/**",
    "**/coverage/**",
    "**/*.spec.ts",
    "**/*.spec.html",
    "**/tests/**"
  ]
}
