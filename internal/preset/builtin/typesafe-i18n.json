{
  "name": "typesafe-i18n",
  "displayName": "typesafe-i18n",
  "fileExtensions": [".tsx", ".ts", ".jsx", ".js", ".svelte"],
  "i18nFunctionPatterns": [
    "\\bLL\\.(?P<key>[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)\\(",
    "locale\\.(?P<key>[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)\\("
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "className=",
    "data-testid=",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/i18n/**/*.json",
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["typesafe-i18n"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
