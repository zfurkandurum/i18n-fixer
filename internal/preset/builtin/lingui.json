{
  "name": "lingui",
  "displayName": "LinguiJS",
  "fileExtensions": [".tsx", ".ts", ".jsx", ".js"],
  "i18nFunctionPatterns": [
    "\\bt`(?P<key>[^`]+)`",
    "\\bmsg`(?P<key>[^`]+)`",
    "i18n\\._\\(['\"](?P<key>[^'\"]+)['\"]",
    "Trans[^>]*id=['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "className=",
    "data-testid=",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["@lingui/core", "@lingui/react", "@lingui/macro"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
