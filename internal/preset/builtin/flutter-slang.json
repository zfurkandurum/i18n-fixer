{
  "name": "flutter-slang",
  "displayName": "Flutter (slang)",
  "fileExtensions": [".dart"],
  "i18nFunctionPatterns": [
    "\\bt\\.(?P<key>[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)+)",
    "AppLocale\\.[a-zA-Z]+\\.translations\\.(?P<key>[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)"
  ],
  "hardcodedStringPatterns": [
    "Text\\([\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "tooltip:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "hintText:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "labelText:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "title:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^assets/",
    "^packages/",
    "^[0-9.,]+$",
    "^\\s*$",
    "import\\s",
    "^[a-z_]+$"
  ],
  "i18nFilePatterns": [
    "**/i18n/**/*.json",
    "**/i18n/**/*.arb",
    "**/assets/i18n/**/*.json",
    "**/assets/i18n/**/*.arb",
    "**/locales/**/*.json",
    "**/lang/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "pubspec.yaml", "containsAny": ["slang"] }
  ],
  "ignorePatterns": [
    "**/.dart_tool/**",
    "**/build/**",
    "**/.git/**",
    "**/*.g.dart",
    "**/*.freezed.dart",
    "**/*_strings.g.dart",
    "**/*_test.dart",
    "**/test/**"
  ]
}
