{
  "name": "ember-intl",
  "displayName": "Ember.js (ember-intl)",
  "fileExtensions": [".js", ".ts", ".hbs"],
  "i18nFunctionPatterns": [
    "intl\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\{\\{t\\s+['\"](?P<key>[^'\"]+)['\"]",
    "this\\.intl\\.t\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=\"(?P<str>[^\"]{2,})\""
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{\\{",
    "class=\"",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/translations/**/*.json",
    "**/translations/**/*.yaml",
    "**/translations/**/*.yml",
    "**/locales/**/*.json",
    "**/i18n/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["ember-intl"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/tmp/**",
    "**/.git/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/tests/**"
  ]
}
