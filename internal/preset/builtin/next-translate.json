{
  "name": "next-translate",
  "displayName": "Next.js (next-translate)",
  "fileExtensions": [
    ".tsx",
    ".ts",
    ".jsx",
    ".js"
  ],
  "i18nFunctionPatterns": [
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]",
    "useTranslation\\(['\"](?P<key>[^'\"]+)['\"]\\)"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]",
    "(?:subtitle|description|helperText|errorText|caption|heading|header|footer)=['\\\"](?P<str>[^'\\\"]{2,})['\\\"]",
    "=>[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "return[\\s]+['\"](?P<str>[^'\"]{2,})['\"]",
    "throw new Error\\(['\"](?P<str>[^'\"]{2,})['\"]",
    "(?:subtitle|description|helperText|errorText|caption|heading|header|footer)=['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "className=",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    {
      "file": "package.json",
      "containsAny": [
        "next-translate"
      ]
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.next/**",
    "**/out/**",
    "**/.git/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
