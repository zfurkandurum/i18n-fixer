{
  "name": "react-intl",
  "displayName": "React (FormatJS/react-intl)",
  "fileExtensions": [".tsx", ".ts", ".jsx", ".js"],
  "i18nFunctionPatterns": [
    "intl\\.formatMessage\\(\\{[^}]*id:\\s*['\"](?P<key>[^'\"]+)['\"]",
    "<FormattedMessage[^>]+id=['\"](?P<key>[^'\"]+)['\"]",
    "defineMessages\\([^)]*['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "className=",
    "data-testid=",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "src/locales/**/*.json",
    "src/lang/**/*.json",
    "src/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["react-intl", "@formatjs/intl"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**", "**/dist/**", "**/build/**",
    "**/.git/**", "**/coverage/**"
  ]
}
