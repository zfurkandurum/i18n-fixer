{
  "name": "i18next",
  "displayName": "i18next (standalone)",
  "fileExtensions": [".ts", ".js", ".mjs", ".cjs"],
  "i18nFunctionPatterns": [
    "i18next\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "i18n\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    "res\\.(?:send|json)\\(['\"](?P<str>[A-Z][^'\"]{2,})['\"]",
    "throw new Error\\(['\"](?P<str>[^'\"]{2,})['\"]",
    "new Error\\(['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "import\\s",
    "require\\("
  ],
  "i18nFilePatterns": [
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["\"i18next\""] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/*.test.*",
    "**/*.spec.*"
  ]
}
