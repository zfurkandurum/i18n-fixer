{
  "name": "react-native-i18n-js",
  "displayName": "React Native (i18n-js)",
  "fileExtensions": [
    ".tsx",
    ".ts",
    ".jsx",
    ".js"
  ],
  "i18nFunctionPatterns": [
    "I18n\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "i18n\\.t\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|accessibilityLabel|accessibilityHint|title)=['\"](?P<str>[^'\"]{2,})['\"]",
    "Alert\\.alert\\(['\"](?P<str>[^'\"]{2,})['\"]",
    "(?:subtitle|description|helperText|errorText|caption|heading|header|footer)=['\\\"](?P<str>[^'\\\"]{2,})['\\\"]",
    "=>[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "return[\\s]+['\"](?P<str>[^'\"]{2,})['\"]",
    "throw new Error\\(['\"](?P<str>[^'\"]{2,})['\"]",
    "(?:subtitle|description|helperText|errorText|caption|heading|header|footer)=['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "style=",
    "import\\s",
    "require\\("
  ],
  "i18nFilePatterns": [
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    {
      "file": "package.json",
      "containsAny": [
        "i18n-js"
      ]
    }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/android/build/**",
    "**/ios/Pods/**",
    "**/.git/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
