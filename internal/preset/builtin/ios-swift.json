{
  "name": "ios-swift",
  "displayName": "iOS (Swift)",
  "fileExtensions": [
    ".swift"
  ],
  "i18nFunctionPatterns": [
    "NSLocalizedString\\(['\"](?P<key>[^'\"]+)['\"]",
    "String\\(localized:[\\s]*['\"](?P<key>[^'\"]+)['\"]",
    "Text\\(['\"](?P<key>[^'\"]+)['\"][\\s]*,[\\s]*tableName"
  ],
  "hardcodedStringPatterns": [
    "Text\\(['\"](?P<str>[A-Z][^'\"]{2,})['\"]\\)",
    "\\.text[\\s]*=[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "title:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "message:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "placeholder:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "=>[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "return[\\s]+['\"](?P<str>[^'\"]{2,})['\"]",
    "subtitle:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "description:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "accessibilityLabel:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^#[0-9a-fA-F]+$",
    "^\\s*$",
    "^[0-9.,]+$",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/*.lproj/Localizable.strings",
    "**/Localizable.xcstrings"
  ],
  "i18nFileFormat": "strings",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    {
      "file": "Package.swift"
    }
  ],
  "ignorePatterns": [
    "**/Pods/**",
    "**/DerivedData/**",
    "**/.build/**",
    "**/.git/**",
    "**/*Tests.swift",
    "**/*Test.swift",
    "**/Tests/**"
  ]
}
