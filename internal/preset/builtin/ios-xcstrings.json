{
  "name": "ios-xcstrings",
  "displayName": "iOS (String Catalog / .xcstrings)",
  "fileExtensions": [
    ".swift"
  ],
  "i18nFunctionPatterns": [
    "Text\\(['\"](?P<key>[^'\"]+)['\"][\\s]*,[\\s]*bundle:",
    "String\\(localized:[\\s]*['\"](?P<key>[^'\"]+)['\"]",
    "NSLocalizedString\\(['\"](?P<key>[^'\"]+)['\"]",
    "LocalizedStringKey\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    "Text\\(['\"](?P<str>[A-Z][^'\"]{2,})['\"]\\)",
    "Label\\(['\"](?P<str>[^'\"]{2,})['\"]",
    "Button\\(['\"](?P<str>[^'\"]{2,})['\"]",
    "\\.navigationTitle\\(['\"](?P<str>[^'\"]{2,})['\"]",
    "=>[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "return[\\s]+['\"](?P<str>[^'\"]{2,})['\"]",
    "subtitle:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "description:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "accessibilityLabel:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^#[0-9a-fA-F]+$",
    "^\\s*$",
    "^[0-9.,]+$",
    "import\\s",
    "^[a-z_]"
  ],
  "i18nFilePatterns": [
    "**/Localizable.xcstrings",
    "**/*.xcstrings"
  ],
  "i18nFileFormat": "xcstrings",
  "keyStyle": "flat",
  "keySeparator": ".",
  "projectMarkers": [
    {
      "file": "*.xcodeproj/project.pbxproj"
    }
  ],
  "ignorePatterns": [
    "**/Pods/**",
    "**/DerivedData/**",
    "**/.build/**",
    "**/.git/**",
    "**/*Tests.swift",
    "**/*Test.swift",
    "**/Tests/**"
  ]
}
