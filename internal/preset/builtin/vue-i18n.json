{
  "name": "vue-i18n",
  "displayName": "Vue (vue-i18n)",
  "fileExtensions": [".vue", ".ts", ".js"],
  "i18nFunctionPatterns": [
    "\\$t\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\$tc\\(['\"](?P<key>[^'\"]+)['\"]",
    "v-t=\"['\"](?P<key>[^'\"]+)['\"]",
    "i18n\\.t\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=\"(?P<str>[^\"]{2,})\""
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "class=\"",
    "import\\s",
    "require\\("
  ],
  "i18nFilePatterns": [
    "src/locales/**/*.json",
    "src/lang/**/*.json",
    "src/i18n/**/*.json",
    "src/locales/**/*.yaml",
    "src/locales/**/*.yml"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["vue-i18n"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**", "**/dist/**", "**/.git/**"
  ]
}
