{
  "name": "inlang-paraglide",
  "displayName": "Inlang / Paraglide",
  "fileExtensions": [".tsx", ".ts", ".jsx", ".js", ".svelte", ".vue"],
  "i18nFunctionPatterns": [
    "\\bm\\.(?P<key>[a-zA-Z_][a-zA-Z0-9_]*)\\("
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "className=",
    "data-testid=",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/messages/**/*.json",
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": "_",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["@inlang/paraglide", "paraglide"] },
    { "file": "project.inlang/settings.json" }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/paraglide/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
