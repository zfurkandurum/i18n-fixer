{
  "name": "react-native",
  "displayName": "React Native",
  "fileExtensions": [".tsx", ".ts", ".jsx", ".js"],
  "i18nFunctionPatterns": [
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]",
    "i18next\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "I18n\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "strings\\.(?P<key>[a-zA-Z_][a-zA-Z0-9_.]*)"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|accessibilityLabel|accessibilityHint|title)=['\"](?P<str>[^'\"]{2,})['\"]",
    "Alert\\.alert\\(['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "style=",
    "import\\s",
    "require\\("
  ],
  "i18nFilePatterns": [
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["react-native"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/android/build/**",
    "**/ios/Pods/**",
    "**/.git/**",
    "**/coverage/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
