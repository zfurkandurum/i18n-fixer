{
  "name": "react-i18next",
  "displayName": "React (i18next)",
  "fileExtensions": [".tsx", ".ts", ".jsx", ".js"],
  "i18nFunctionPatterns": [
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]",
    "i18next\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "<Trans[^>]+i18nKey=['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=['\"](?P<str>[^'\"]{2,})['\"]",
    "(?:alert|confirm|prompt)\\(['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^[a-z]+(-[a-z]+)*$",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "className=",
    "data-testid=",
    "import\\s",
    "require\\("
  ],
  "i18nFilePatterns": [
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json",
    "**/messages/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["react-i18next", "i18next"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.git/**",
    "**/coverage/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
