{
  "name": "ngx-translate",
  "displayName": "Angular (ngx-translate)",
  "fileExtensions": [".ts", ".html"],
  "i18nFunctionPatterns": [
    "translate\\.instant\\(['\"](?P<key>[^'\"]+)['\"]",
    "translate\\.get\\(['\"](?P<key>[^'\"]+)['\"]",
    "'(?P<key>[A-Z][A-Z0-9_]*(\\.[A-Z][A-Z0-9_]*)*)'\\s*\\|\\s*translate",
    "\"(?P<key>[A-Z][A-Z0-9_]*(\\.[A-Z][A-Z0-9_]*)*)\"\\s*\\|\\s*translate",
    "\\[translate\\]=\"'(?P<key>[^']+)'\"",
    "translateService\\.instant\\(['\"](?P<key>[^'\"]+)['\"]",
    "'(?P<key>[a-z][a-zA-Z0-9._]*)'\\s*\\|\\s*translate",
    "\"(?P<key>[a-z][a-zA-Z0-9._]*)\"\\s*\\|\\s*translate",
    "\\b[a-zA-Z_][a-zA-Z0-9_]*\\.t\\(['\"](?P<key>[^'\"]+)['\"]",
    "label:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "label:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "title:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "title:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "value:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "value:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "header:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "header:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "tooltip:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "tooltip:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "breadcrumb:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "breadcrumb:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "permission:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "permission:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "message:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "message:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "acceptLabel:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "acceptLabel:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "rejectLabel:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "rejectLabel:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "detail:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "detail:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "summary:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "summary:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "description:\\s*'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'",
    "description:\\s*\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "\\[placeholder\\]=\"'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'\"",
    "\\[label\\]=\"'(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)'\"",
    "\\btitle=\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\"",
    "\\bsubtitle=\"(?P<key>[A-Z][A-Z0-9_]*\\.[A-Z0-9_.]+)\""
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=\"(?P<str>[^\"]{2,})\""
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "^[A-Z][A-Z0-9_]*(\\.[A-Z0-9_]+)+$",
    "^\\{\\{",
    "\\|\\s*translate",
    "class=\"",
    "\\*ngIf",
    "\\*ngFor",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/i18n/**/*.json",
    "**/locale/**/*.json",
    "**/locales/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json",
    "**/assets/i18n/**/*.json",
    "**/assets/locales/**/*.json",
    "**/assets/lang/**/*.json",
    "**/assets/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["@ngx-translate/core"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.git/**",
    "**/.angular/**",
    "**/coverage/**",
    "**/*.spec.ts",
    "**/*.spec.html",
    "**/tests/**"
  ]
}
