{
  "name": "flutter-getx",
  "displayName": "Flutter (GetX localization)",
  "fileExtensions": [".dart"],
  "i18nFunctionPatterns": [
    "['\"](?P<key>[a-zA-Z_][a-zA-Z0-9_.]*)['\"]\\s*\\.tr[^a-zA-Z0-9_(]",
    "['\"](?P<key>[a-zA-Z_][a-zA-Z0-9_.]*)['\"]\\s*\\.trArgs\\("
  ],
  "hardcodedStringPatterns": [
    "Text\\([\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "tooltip:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "hintText:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "labelText:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]",
    "title:[\\s]*['\"](?P<str>[^'\"]{2,})['\"]"
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^assets/",
    "^packages/",
    "^[0-9.,]+$",
    "^\\s*$",
    "import\\s",
    "^[a-z_]+$",
    "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+"
  ],
  "i18nFilePatterns": [
    "**/assets/locales/**/*.json",
    "**/assets/translations/**/*.json",
    "**/assets/lang/**/*.json",
    "**/lib/translations/**/*.json",
    "**/locales/**/*.json",
    "**/lang/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "flat",
  "keySeparator": "_",
  "projectMarkers": [
    { "file": "pubspec.yaml", "containsAny": ["get:"] }
  ],
  "ignorePatterns": [
    "**/.dart_tool/**",
    "**/build/**",
    "**/.git/**",
    "**/*.g.dart",
    "**/*.freezed.dart",
    "**/*_test.dart",
    "**/test/**"
  ]
}
