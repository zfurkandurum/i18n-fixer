{
  "name": "svelte-i18n",
  "displayName": "Svelte (svelte-i18n)",
  "fileExtensions": [".svelte", ".ts", ".js"],
  "i18nFunctionPatterns": [
    "\\$_\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\$t\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\$format\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=\"(?P<str>[^\"]{2,})\""
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "^\\{",
    "class=\"",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "**/locales/**/*.json",
    "**/locale/**/*.json",
    "**/i18n/**/*.json",
    "**/lang/**/*.json",
    "**/translations/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["svelte-i18n"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.svelte-kit/**",
    "**/build/**",
    "**/.git/**",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**"
  ]
}
