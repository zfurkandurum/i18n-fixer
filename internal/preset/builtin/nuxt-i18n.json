{
  "name": "nuxt-i18n",
  "displayName": "Nuxt.js (@nuxtjs/i18n)",
  "fileExtensions": [".vue", ".ts", ".js"],
  "i18nFunctionPatterns": [
    "\\$t\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\bt\\(['\"](?P<key>[^'\"]+)['\"]",
    "\\$tc\\(['\"](?P<key>[^'\"]+)['\"]"
  ],
  "hardcodedStringPatterns": [
    ">[\\s]*(?P<str>[A-Z][a-zA-Z0-9 ,.!?'\\-]{2,})[\\s]*<",
    "(?:placeholder|title|alt|aria-label|label)=\"(?P<str>[^\"]{2,})\""
  ],
  "hardcodedStringExclusions": [
    "^https?://",
    "^[/#.]",
    "^\\s*$",
    "^[0-9.,]+$",
    "class=\"",
    "import\\s"
  ],
  "i18nFilePatterns": [
    "locales/**/*.json",
    "i18n/**/*.json",
    "lang/**/*.json"
  ],
  "i18nFileFormat": "json",
  "keyStyle": "nested",
  "keySeparator": ".",
  "projectMarkers": [
    { "file": "package.json", "containsAny": ["@nuxtjs/i18n"] }
  ],
  "ignorePatterns": [
    "**/node_modules/**", "**/.nuxt/**", "**/.output/**", "**/.git/**"
  ]
}
