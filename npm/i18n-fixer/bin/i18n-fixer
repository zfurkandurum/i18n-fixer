#!/usr/bin/env node

const { execFileSync } = require("child_process");
const os = require("os");
const path = require("path");

const PLATFORMS = {
  "darwin-arm64": "@zfurkandurum/i18n-fixer-darwin-arm64",
  "darwin-x64": "@zfurkandurum/i18n-fixer-darwin-x64",
  "linux-x64": "@zfurkandurum/i18n-fixer-linux-x64",
  "linux-arm64": "@zfurkandurum/i18n-fixer-linux-arm64",
  "win32-x64": "@zfurkandurum/i18n-fixer-win32-x64",
  "win32-arm64": "@zfurkandurum/i18n-fixer-win32-arm64",
};

const platformKey = `${os.platform()}-${os.arch()}`;
const pkg = PLATFORMS[platformKey];

if (!pkg) {
  console.error(
    `i18n-fixer: unsupported platform ${platformKey}\n` +
    `Supported: ${Object.keys(PLATFORMS).join(", ")}\n` +
    `Install the Go binary directly: go install github.com/zfurkandurum/i18n-fixer/cmd/i18n-fixer@latest`
  );
  process.exit(1);
}

const ext = os.platform() === "win32" ? ".exe" : "";

let binPath;
try {
  binPath = require.resolve(`${pkg}/bin/i18n-fixer${ext}`);
} catch {
  console.error(
    `i18n-fixer: could not find binary for ${platformKey}\n` +
    `Try reinstalling: npm install i18n-fixer`
  );
  process.exit(1);
}

try {
  execFileSync(binPath, process.argv.slice(2), { stdio: "inherit" });
} catch (err) {
  if (err.status !== undefined) {
    process.exit(err.status);
  }
  throw err;
}
